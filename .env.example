PORT=4060
JWT_SECRET=change-me-to-a-long-random-string
DATABASE_URL=
APP_URL=http://localhost:5178
NODE_ENV=development

# Invite email (https://resend.com)
RESEND_API_KEY=
MAIL_FROM=HeirReady <onboarding@resend.dev>

# Paddle Billing (USD — cards worldwide) https://vendors.paddle.com
# Client-side token (Paddle.js) + server API key + webhook secret
PADDLE_CLIENT_TOKEN=
PADDLE_API_KEY=
PADDLE_ENV=sandbox
# Webhook: https://YOUR_DOMAIN/api/billing/webhook
# Events: transaction.completed, subscription.created, subscription.updated, subscription.canceled, subscription.activated
PADDLE_WEBHOOK_SECRET=
# Optional: pin catalog Price IDs for full-year subscriptions (otherwise ad-hoc USD prices)
# PADDLE_PRICE_FAMILY=
# PADDLE_PRICE_DIASPORA=
# PADDLE_PRICE_COUNSEL=
# PADDLE_PRICE_FAMILY_CARE=
# PADDLE_PRICE_DIASPORA_CARE=
# Optional amount overrides in USD cents
# PADDLE_AMOUNT_FAMILY=1900
# PADDLE_AMOUNT_DIASPORA=14900
# PADDLE_AMOUNT_COUNSEL=1900
# PADDLE_AMOUNT_FAMILY_CARE=3900
# PADDLE_AMOUNT_DIASPORA_CARE=29900

# Public Contact / Legal (shown on site — no personal phone/name)
SUPPORT_EMAIL=support@heirready.com
BUSINESS_BRAND=HeirReady
BUSINESS_LEGAL_NAME=
BUSINESS_ADDRESS=
BUSINESS_EMAIL=support@heirready.com
BUSINESS_HOURS=Mon–Sat, 10:00–18:00 IST
BUSINESS_GRIEVANCE_NAME=HeirReady Support
BUSINESS_GRIEVANCE_EMAIL=support@heirready.com

# Human onboarding waitlist only (Pricing form → private inbox, not on public pages)
ONBOARDING_EMAIL=

# Counsel verification admin (POST /api/admin/lawyers/:id/verify with X-Admin-Key)
ADMIN_API_KEY=
